{
  "_version": "1.82.0",
  "sap.app": {
    "id": "purchaseorders",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.20.4",
      "toolsId": "5e9d3865-46ea-4d03-8cff-d9e22f522623"
    },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/CatalogService/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.01"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.145.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {},
        "sap.f": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "purchaseorders.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {
        "flexibleColumnLayout": {
          "defaultTwoColumnLayoutType": "TwoColumnsBeginExpanded",
          "defaultThreeColumnLayoutType": "ThreeColumnsMidExpanded"
        },
        "routerClass": "sap.f.routing.Router"
      },
      "routes": [
        {
          "pattern": ":?query:",
          "name": "PurchaseOrderSrvList",
          "target": [
            "PurchaseOrderSrvList"
          ]
        },
        {
          "pattern": "PurchaseOrderSrv({key}):?query:",
          "name": "PurchaseOrderSrvObjectPage",
          "target": [
            "PurchaseOrderSrvList",
            "PurchaseOrderSrvObjectPage"
          ]
        },
        {
          "pattern": "PurchaseOrderSrv({key})/Items({key2}):?query:",
          "name": "PurchaseItemSrvObjectPage",
          "target": [
            "PurchaseOrderSrvList",
            "PurchaseOrderSrvObjectPage",
            "PurchaseItemSrvObjectPage"
          ]
        }
      ],
      "targets": {
        "PurchaseOrderSrvList": {
          "type": "Component",
          "id": "PurchaseOrderSrvList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/PurchaseOrderSrv",
              "variantManagement": "Page",
              "navigation": {
                "PurchaseOrderSrv": {
                  "detail": {
                    "route": "PurchaseOrderSrvObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable"
                  }
                }
              },
              "initialLoad": "Enabled"
            }
          },
          "controlAggregation": "beginColumnPages",
          "contextPattern": ""
        },
        "PurchaseOrderSrvObjectPage": {
          "type": "Component",
          "id": "PurchaseOrderSrvObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/PurchaseOrderSrv",
              "navigation": {
                "Items": {
                  "detail": {
                    "route": "PurchaseItemSrvObjectPage"
                  }
                }
              }
            }
          },
          "controlAggregation": "midColumnPages",
          "contextPattern": "/PurchaseOrderSrv({key})"
        },
        "PurchaseItemSrvObjectPage": {
          "type": "Component",
          "id": "PurchaseItemSrvObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/PurchaseOrderSrv/Items"
            }
          },
          "controlAggregation": "endColumnPages",
          "contextPattern": "/PurchaseOrderSrv({key})/Items({key2})"
        }
      }
    },
    "rootView": {
      "viewName": "sap.fe.templates.RootContainer.view.Fcl",
      "type": "XML",
      "async": true,
      "id": "appRootView"
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  },
  "sap.fe": {
    "app": {
      "enableLazyLoading": true
    }
  }
}

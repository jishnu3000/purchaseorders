{
  "xsappname": "purchaseorders",
  "tenant-mode": "dedicated",
  "scopes": [
    {
      "name": "$XSAPPNAME.Viewer",
      "description": "Viewer Role"
    },
    {
      "name": "$XSAPPNAME.Admin",
      "description": "Administrator Role"
    }
  ],
  "attributes": [
    {
      "name": "myCountry",
      "description": "Country",
      "valueType": "string"
    }
  ],
  "role-templates": [
    {
      "name": "Viewer",
      "description": "Viewer Role",
      "scope-references": [
        "$XSAPPNAME.Viewer"
      ],
      "attribute-references": [
        {
          "name": "myCountry"
        }
      ]
    },
    {
      "name": "Admin",
      "description": "Administrator Role",
      "scope-references": [
        "$XSAPPNAME.Admin"
      ]
    }
  ],
  "role-collections": [
    {
      "name": "PO_VIEWER",
      "description": "Viewer Role",
      "role-template-references": [
        "$XSAPPNAME.Viewer"
      ]
    },
    {
      "name": "PO_ADMIN",
      "description": "Administrator Role",
      "role-template-references": [
        "$XSAPPNAME.Admin"
      ]
    }
  ],
  "authorities": [
    "$ACCEPT_GRANTED_AUTHORITIES"
  ],
  "oauth2-configuration": {
    "token-validity": 9000,
    "redirect-uris": [
      "https://*.cfapps.us10-001.hana.ondemand.com/login/callback"
    ]
  },
  "xsenableasyncservice": "true"
}
